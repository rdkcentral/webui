<?% include('includes/header.jst'); ?>
<?% include('includes/utility.jst'); ?>
<!-- $Id: managed_services_add.jst 2943 2009-08-25 20:58:43Z slemoine $ -->
<div id="sub-header">
	<?% include('includes/userbar.jst'); ?>
</div><!-- end #sub-header -->
<?% include('includes/nav.jst'); ?>
<script type="text/javascript">
$(document).ready(function() {
    <?% if(is_device_router()) { ?>
	gateway.page.init("Router > Connection > MTA > Line Diagnostics", "nav-mta-line-diagnostics");
    <?% } else { ?>
	gateway.page.init("Gateway > Connection > MTA > Line Diagnostics", "nav-mta-line-diagnostics");
    <?% } ?>

	$("[id^='start_diagnostics']").on("click", function () {
		const line = this.id.replace("start_diagnostics", ""); // 1–8

		if (line < 1 || line > 8) return;

		// Set all fields to InProgress
		["hp", "femf", "rf", "roh", "re"].forEach(function (item) {
			document.getElementById("line" + line + item).value = "InProgress";
		});

		jProgress($.i18n("Check telephony line status, please wait..."), 60);

		$.get(
			"actionHandler/ajaxSet_mta_Line_Diagnostics.jst",
			{ "get_status"+line: "true" },
			function (msg) {
				jHide();

				if (msg["line"+line+"hook"] === "Off-Hook") {
					jConfirm(
						$.i18n("Phone is Off-Hook, do you want to start the test anyway?"),
						$.i18n("Are you sure?"),
						function (ret) {
							if (ret) {
								startDiagnostics(line);
							}
						}
					);
				} else {
					startDiagnostics(line);
				}
			},
			"json"
		);
	});

	function startDiagnostics(line) {
		jProgress($.i18n("This may take several seconds..."), 60);

		$.get(
			"actionHandler/ajaxSet_mta_Line_Diagnostics.jst",
			{ "start_diagnostics"+line: "true" },
			function (msg) {
				["hp", "femf", "rf", "roh", "re"].forEach(function (item) {
					document.getElementById("line" + line + item).value =
						msg["line" + line + item];
				});
				jHide();
			},
			"json"
		);
	}
});
</script>
<div id="content">
    <?% if(is_device_router()) { ?>
	<h1 id="mtalinhead_router">Router > Connection > MTA > Line Diagnostics</h1>
    <?% } else { ?>
	<h1 id="mtalinhead">Gateway > Connection > MTA > Line Diagnostics</h1>
    <?% } ?>
<div id="educational-tip">
<p class="tip" id="mtalintip1">Information related to the MTA Line Diagnostics.</p>
</div>
<?%
	$voice_lines    = getStr("Device.X_CISCO_COM_MTA.LineTableNumberOfEntries");
	for ($i=0; $i <= Number($voice_lines); $i++) {
?>
<div class="module forms">
	<input type="hidden" value="mta_line_diagnostics" name="file"/>
	<input type="hidden" value="admin/" name="dir"/>
	<input type="hidden" name="line<?% echo($i); ?>" id="line<?% echo($i); ?>_name" value="<?% echo($i); ?>" />
	<h2 id="mtalinediag<?% echo($i); ?>">MTA Line <?% echo($i); ?> Diagnostics</h2>
	<div class="form-row">
		<!--div>Hazardous Potential:</div-->
		<span class="valuemta" id="mtalinmess2">Hazardous Potential:</span>
		<label for="line<?% echo($i); ?>hp" class="acs-hide"></label>
		<textarea class="textAreaDiagnostic" cols="80" rows="3" value="" id="line<?% echo($i); ?>hp">Not Started</textarea>
	</div>
	<div class="form-row odd">
		<div id="mtalinmess3">Foreign EMF:</div>
		<label for="line<?% echo($i); ?>femf" class="acs-hide"></label>
		<textarea class="textAreaDiagnostic" cols="80" rows="3" value="" id="line<?% echo($i); ?>femf">Not Started</textarea>
	</div>
	<div class="form-row">
		<div id="mtalinmessnew1">Resistive Faults:</div>
		<label for="line<?% echo($i); ?>rf" class="acs-hide"></label>
		<textarea class="textAreaDiagnostic" cols="80" rows="3" value="" id="line<?% echo($i); ?>rf">Not Started</textarea>
	</div>
	<div class="form-row odd">
		<div id="mtalinmess4">Receiver Off Hook:</div>
		<label for="line<?% echo($i); ?>roh" class="acs-hide"></label>
		<textarea class="textAreaDiagnostic" cols="80" rows="3" value="" id="line<?% echo($i); ?>roh">Not Started</textarea>
	</div>
	<div class="form-row">
		<div id="mtalinmess5">Ringer Equivalency:</div>
		<label for="line<?% echo($i); ?>re" class="acs-hide"></label>
		<textarea class="textAreaDiagnostic" cols="80" rows="3" value="" id="line<?% echo($i); ?>re">Not Started</textarea>
	</div>
	<div class="form-btn odd">
		<input id="start_diagnostics<?% echo($i); ?>" type="button" value="Start Diagnostics" class="btn" />
	</div>
	<input type="hidden" name="webcheck">
</div> <!-- end .module -->
<?% } ?>
</div><!-- end #content -->
<!-- Page Specific Script -->
<?% include('includes/footer.jst'); ?>
